{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"types": ["vite/client"],
		"rootDirs": ["."],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@cyop/api": ["../../packages/api/src/index.ts"],
			"@cyop/api/*": ["../../packages/api/src/*"],
			"@cyop/auth": ["../../packages/auth/src/index.ts"],
			"@cyop/auth/*": ["../../packages/auth/src/*"],
			"@cyop/db": ["../../packages/db/src/index.ts"],
			"@cyop/db/*": ["../../packages/db/src/*"],
			"@cyop/ui": ["../../packages/ui/dist"],
			"@cyop/ui/*": ["../../packages/ui/dist/*"]
		}
	}
}
